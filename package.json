{
  "name": "phonemic",
  "version": "0.0.0",
  "private": true,
  "description": "PhoneMic monorepo workspace root (Tauri desktop + Vue 3 mobile web client)",
  "license": "MIT OR Apache-2.0",
  "homepage": "https://github.com/your-org/phonemic",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/phonemic.git"
  },
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "lint": "pnpm -r --if-present lint",
    "lint:fix": "pnpm -r --if-present lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "build": "pnpm -r --if-present build",
    "clean": "pnpm -r --if-present clean",
    "gen:ts-types": "node scripts/gen-ts-types.mjs",
    "check:ts-types": "node scripts/gen-ts-types.mjs --check"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "8.12.2",
    "@typescript-eslint/parser": "8.12.2",
    "eslint": "9.13.0",
    "prettier": "3.3.3",
    "typescript": "5.6.3"
  }
}
